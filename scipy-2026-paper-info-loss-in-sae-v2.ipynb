# ── Extract activations ──────────────────────────────
# Last-token pooling: captures the model's generation decision state.


def get_activations_last_token(prompts, model, sae, layer=8, batch_size=4):
    """
    Extracts:
      raw_acts  [N, d_model] — last-token residual stream activations
      sae_feats [N, d_sae]   — last-token SAE feature activations
    """
    raw_acts_list  = []
    sae_feats_list = []
    hook_name = f"blocks.{layer}.hook_resid_pre"

    for i in range(0, len(prompts), batch_size):
        batch  = prompts[i:i+batch_size]
        tokens = model.to_tokens(batch, prepend_bos=True)

        with torch.no_grad():
            _, cache = model.run_with_cache(tokens, names_filter=hook_name)
            acts      = cache[hook_name]           # [batch, seq_len, d_model]
            acts_last = acts[:, -1, :]             # [batch, d_model]
            sae_out   = sae.encode(acts_last)      # [batch, d_sae]

        raw_acts_list.append(acts_last.cpu().float().numpy())
        sae_feats_list.append(sae_out.cpu().float().numpy())

        if i % 20 == 0:
            print(f"  Processed {i}/{len(prompts)}")

    return (
        np.concatenate(raw_acts_list,  axis=0),
        np.concatenate(sae_feats_list, axis=0),
    )


print("Extracting activations...")
raw_acts, sae_feats = get_activations_last_token(
    all_prompts, model, sae, layer=8
)

print(f"\nRaw activations shape: {raw_acts.shape}")    # [240, 768]
print(f"SAE features shape:    {sae_feats.shape}")    # [240, 24576]

# Save — don't recompute
with open(f"{SAVE_DIR}activations.pkl", "wb") as f:
    pickle.dump({
        "raw":      raw_acts,
        "sae":      sae_feats,
        "labels":   labels,
        "entropies": entropies,
        "prompts":  all_prompts,
    }, f)
print(f"Saved to {SAVE_DIR}activations.pkl")


# ── Classifier comparison (main test ) ─────────────

X_raw_train, X_raw_test, y_train, y_test = train_test_split(
    raw_acts, labels, test_size=0.3, random_state=42, stratify=labels
)
X_sae_train, X_sae_test, _, _ = train_test_split(
    sae_feats, labels, test_size=0.3, random_state=42, stratify=labels
)

sc_raw = StandardScaler()
X_raw_train_s = sc_raw.fit_transform(X_raw_train)
X_raw_test_s  = sc_raw.transform(X_raw_test)

sc_sae = StandardScaler()
X_sae_train_s = sc_sae.fit_transform(X_sae_train)
X_sae_test_s  = sc_sae.transform(X_sae_test)

clf_raw = LogisticRegression(max_iter=1000, C=1.0, random_state=42)
clf_raw.fit(X_raw_train_s, y_train)
acc_raw = accuracy_score(y_test, clf_raw.predict(X_raw_test_s))

clf_sae = LogisticRegression(max_iter=1000, C=1.0, random_state=42)
clf_sae.fit(X_sae_train_s, y_train)
acc_sae = accuracy_score(y_test, clf_sae.predict(X_sae_test_s))

acc_baseline = max(labels.mean(), 1 - labels.mean())

print("=" * 52)
print(f"Baseline (majority class):     {acc_baseline:.3f}")
print(f"SAE features (text-mediated):  {acc_sae:.3f}")
print(f"Raw activations:               {acc_raw:.3f}")
print(f"Information lost by SAE:       {acc_raw - acc_sae:.3f}")
print("=" * 52)

print("\nRaw Activation Classifier:")
print(classification_report(
    y_test, clf_raw.predict(X_raw_test_s),
    target_names=["Confident", "Uncertain"]
))

print("SAE Feature Classifier:")
print(classification_report(
    y_test, clf_sae.predict(X_sae_test_s),
    target_names=["Confident", "Uncertain"]
))


# ── tatistical validation (paired t-test - agian something new or me ) ──────────
# Paired t-test is more powerful than CI comparison because both
# classifiers are evaluated on the same folds — scores are paired.

from scipy.stats import ttest_rel, wilcoxon

def cv_scores(X, y, n_splits=10):
    cv = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=42)
    scores = []
    for train_idx, test_idx in cv.split(X, y):
        sc = StandardScaler()
        X_tr = sc.fit_transform(X[train_idx])
        X_te = sc.transform(X[test_idx])
        clf  = LogisticRegression(max_iter=1000, random_state=42)
        clf.fit(X_tr, y[train_idx])
        scores.append(accuracy_score(y[test_idx], clf.predict(X_te)))
    return np.array(scores)


print("Running 10-fold cross-validation...\n")
scores_raw = cv_scores(raw_acts,  labels)
scores_sae = cv_scores(sae_feats, labels)

acc_raw_cv = scores_raw.mean()
acc_sae_cv = scores_sae.mean()

t_stat,  p_value  = ttest_rel(scores_raw, scores_sae, alternative="greater")
w_stat,  w_pvalue = wilcoxon(scores_raw,  scores_sae, alternative="greater")

print(f"Baseline:         0.500")
print(f"SAE features:     {acc_sae_cv:.3f}")
print(f"Raw activations:  {acc_raw_cv:.3f}")
print(f"Information loss: {acc_raw_cv - acc_sae_cv:.3f}")
print()
print(f"Paired t-test:        t={t_stat:.3f},  p={p_value:.4f}")
print(f"Wilcoxon signed-rank: W={w_stat:.1f},  p={w_pvalue:.4f}")
print()
print("Per-fold gaps:")
for i, (r, s) in enumerate(zip(scores_raw, scores_sae)):
    direction = "✓" if r > s else "✗"
    print(f"  Fold {i+1:2d}: raw={r:.3f}  sae={s:.3f}  gap={r-s:+.3f}  {direction}")
print(f"\nPositive gaps: {sum(scores_raw > scores_sae)}/10 folds")
if p_value < 0.05:
    print("\n✓ p < 0.05 — information loss is statistically significant.")
else:
    print("\n~ p ≥ 0.05 — gap is consistent in direction but not yet significant.")


# ── Per Layer  ──────────────────────────────────────
# Find which layer shows the largest information loss gap.
# This determines which layer to feature in the paper.

print("Running layer sweep (this takes a few minutes)...\n")
layer_results = {}

for layer in [2, 4, 6, 8, 10, 11]:
    raw_l, sae_l = get_activations_last_token(
        all_prompts, model, sae, layer=layer
    )
    s_raw = cv_scores(raw_l, labels)
    s_sae = cv_scores(sae_l, labels)
    acc_r = s_raw.mean()
    acc_s = s_sae.mean()
    layer_results[layer] = {
        "raw": acc_r, "sae": acc_s,
        "gap": acc_r - acc_s,
    }
    print(f"Layer {layer:2d}:  raw={acc_r:.3f}  sae={acc_s:.3f}  gap={acc_r - acc_s:+.3f}")

best_layer = max(layer_results, key=lambda l: layer_results[l]["gap"])
print(f"\nLargest gap at layer {best_layer}: {layer_results[best_layer]['gap']:.3f}")


# ──  Paper figure ────────────────────────────────────

fig, axes = plt.subplots(1, 2, figsize=(14, 5))

