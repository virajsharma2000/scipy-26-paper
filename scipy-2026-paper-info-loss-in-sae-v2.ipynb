ax.set_title("Information Retained About Model Behavior\nSAE Features vs. Raw Activations",
             fontsize=12)

for bar, acc in zip(bars, accuracies):
    ax.text(bar.get_x() + bar.get_width()/2, acc + 0.01,
            f"{acc:.3f}", ha="center", fontsize=11, fontweight="bold")

# Annotate the gap
ax.annotate("",
    xy=(2, acc_raw_cv), xytext=(1, acc_sae_cv),
    arrowprops=dict(arrowstyle="<->", color="red", lw=2)
)
ax.text(1.5, (acc_raw_cv + acc_sae_cv) / 2,
        f"  Δ={acc_raw_cv - acc_sae_cv:.3f}\n  (info lost)",
        color="red", fontsize=10)

# ── Right: Per Layer  ──
ax2 = axes[1]
layers_list = sorted(layer_results.keys())
gaps        = [layer_results[l]["gap"]  for l in layers_list]
raw_accs    = [layer_results[l]["raw"]  for l in layers_list]
sae_accs    = [layer_results[l]["sae"]  for l in layers_list]

ax2.plot(layers_list, raw_accs, "o-", color="#2a9d8f",
         label="Raw activations", linewidth=2, markersize=7)
ax2.plot(layers_list, sae_accs, "s--", color="#f4a261",
         label="SAE features", linewidth=2, markersize=7)
ax2.fill_between(layers_list, raw_accs, sae_accs,
                 alpha=0.15, color="red", label="Information gap")
ax2.axhline(0.5, linestyle=":", color="gray", alpha=0.4)
ax2.set_xlabel("Transformer Layer", fontsize=11)
ax2.set_ylabel("CV Accuracy", fontsize=11)
ax2.set_title("Information Loss by Layer\n(gap = behaviorally relevant signal lost by SAE)",
              fontsize=12)
ax2.legend(fontsize=10)
ax2.set_xticks(layers_list)
ax2.set_ylim(0.4, 1.05)

plt.tight_layout()
plt.savefig(f"{SAVE_DIR}experiment1_information_loss.pdf",
            dpi=300, bbox_inches="tight")
plt.savefig(f"{SAVE_DIR}experiment1_information_loss.png",
            dpi=150, bbox_inches="tight")
plt.show()
print(f"Figure saved to {SAVE_DIR}")


