# ── Compute entropy-based behavioral labels - this is someting I learnt as 
# a part of running this information experiment  ──────────

# "The capital of France is..."   → model assigns high probability to "Paris"
#                               → low entropy → Class 0

#"The capital of Valdoria is..." → model has no grounded answer
#                               → probability spreads across hundreds of tokens
#                               → high entropy → Class 1
# High entropy = uncertain/confabulating (class 1)
# Low entropy  = confident/grounded     (class 0)

def get_output_entropy(prompts, model, batch_size=4):
    """
    Returns Shannon entropy of the next-token distribution
    for each prompt. This is the model's behavioral signal.
    """
    entropies = []

    for i in range(0, len(prompts), batch_size):
        batch = prompts[i:i+batch_size]
        tokens = model.to_tokens(batch, prepend_bos=True)

        with torch.no_grad():
            logits = model(tokens)                        # [batch, seq_len, vocab]
            last_logits = logits[:, -1, :]                # [batch, vocab]
            probs = F.softmax(last_logits, dim=-1)
            entropy = -torch.sum(
                probs * torch.log(probs + 1e-10), dim=-1  # [batch or group it]
            )
            entropies.extend(entropy.cpu().numpy())

        if i % 40 == 0:
            print(f"  Entropy computed for {i}/{len(prompts)} prompts")

    return np.array(entropies)


print("Computing output entropy for all prompts...")
entropies = get_output_entropy(all_prompts, model)

# Split at median — guarantees perfectly balanced classes by construction
median_entropy = np.median(entropies)
labels = (entropies > median_entropy).astype(int)

print(f"\nEntropy statistics:")
print(f"  Min:    {entropies.min():.3f}")
print(f"  Median: {median_entropy:.3f}  (split threshold)")
print(f"  Max:    {entropies.max():.3f}")
print(f"\nClass balance:")
print(f"  Class 0 (confident/grounded): {(labels==0).sum()}")
print(f"  Class 1 (uncertain/confab):   {(labels==1).sum()}")

# Sanity check: do prompt categories align with entropy?
factual_entropy    = entropies[:len(factual_prompts)]
counter_entropy    = entropies[len(factual_prompts):]
print(f"\nEntropy by prompt type:")
