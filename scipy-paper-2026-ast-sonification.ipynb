<script>
// ── State ────────────────────────────────────────────────────
var BUCKETS  = 32;
var acts     = new Float32Array(BUCKETS);   // current activation state
var actTgt   = new Float32Array(BUCKETS);   // interpolation target
var decayT   = 0, activated = false;
var busy     = false;

// Global params
var G = { master: 60, reverb: 30, decay: 8, hbrate: 48 };

// Layer params + enabled state
var L = {
  tonal:   { on:true,  flo:80,  fhi:800, det:8,  vol:40 },
  spatial: { on:true,  wid:80,  pit:300, spd:6,  vol:30 },
  rhythm:  { on:true,  blo:30,  bhi:180, pun:60, vol:35 },
};

function gp(k, v, vid) {
  G[k] = parseFloat(v);
  if (vid) document.getElementById(vid).textContent = v;
  if (k === 'master' && masterGain) masterGain.gain.setTargetAtTime(G.master/100, actx.currentTime, 0.1);
  if (k === 'reverb' && wetGain)    wetGain.gain.setTargetAtTime(G.reverb/100 * 0.9, actx.currentTime, 0.2);
}

function lp(layer, k, v, vid) {
  L[layer][k] = parseFloat(v);
  if (vid) document.getElementById(vid).textContent = v;
}

function toggle(layer) {
  L[layer].on = !L[layer].on;
  var btn = document.getElementById('tog-' + layer);
  if (L[layer].on) {
    btn.classList.remove('off');
    btn.textContent = 'ON';
  } else {
    btn.classList.add('off');
    btn.textContent = 'OFF';
  }
}

// ── VU bars ──────────────────────────────────────────────────
var vuWrap = document.getElementById('vu-wrap');
for (var i = 0; i < BUCKETS; i++) {
  var vb = document.createElement('div');
  vb.className = 'vu-bar';
  vb.id = 'vu-' + i;
  vuWrap.appendChild(vb);
}

function updateVU() {
  for (var i = 0; i < BUCKETS; i++) {
    var v = acts[i], abs = Math.abs(v);
    var el = document.getElementById('vu-' + i);
    el.style.height = Math.max(2, abs * 28) + 'px';
    if (abs < 0.04) {
      el.style.background = 'rgba(0,140,110,0.2)';
    } else if (v > 0) {
      el.style.background = 'rgba('+Math.floor(18+abs*222)+','+Math.floor(205-abs*65)+','+Math.floor(135-abs*125)+',0.9)';
    } else {
      el.style.background = 'rgba(18,'+Math.floor(125-abs*55)+','+Math.floor(205+abs*50)+',0.9)';
    }
  }
}

// ── Audio engine ─────────────────────────────────────────────
var actx = null;
var masterGain, dryGain, wetGain, convolver;
var tonalGain, spatialGain, rhythmGain;
var tonalOscs  = [];   // [{osc, gain, panner}]
var spatialOscs = [];  // [{osc, gain, panner}]
var lastBeat   = 0;
var hbPhase    = 0;

function buildReverb(ctx) {
  var len    = ctx.sampleRate * 2.5;
  var buf    = ctx.createBuffer(2, len, ctx.sampleRate);
  for (var ch = 0; ch < 2; ch++) {
    var d = buf.getChannelData(ch);
    for (var i = 0; i < len; i++) {
      d[i] = (Math.random()*2-1) * Math.pow(1 - i/len, 2.2);
    }
  }
  var c = ctx.createConvolver();
  c.buffer = buf;
  return c;
}

function initAudio() {
  if (actx) return;
  actx = new (window.AudioContext || window.webkitAudioContext)();

  // Master chain: dry/wet reverb → master
  masterGain = actx.createGain();
  masterGain.gain.value = G.master / 100;
  masterGain.connect(actx.destination);

  dryGain = actx.createGain();
  dryGain.gain.value = 0.7;
  dryGain.connect(masterGain);

  convolver = buildReverb(actx);
  wetGain   = actx.createGain();
  wetGain.gain.value = G.reverb / 100 * 0.9;
  convolver.connect(wetGain);
  wetGain.connect(masterGain);

  // ── Tonal: 6 sine oscillators ──────────────────────────────
  tonalGain = actx.createGain();
  tonalGain.gain.value = L.tonal.vol / 100;
  tonalGain.connect(dryGain);
  tonalGain.connect(convolver);

  for (var i = 0; i < 6; i++) {
    var osc = actx.createOscillator();
    var og  = actx.createGain();
    var pan = actx.createStereoPanner();
    osc.type = 'sine';
    osc.frequency.value = 110 + i * 80;
    osc.detune.value    = (i % 2 === 0 ? 1 : -1) * L.tonal.det;
    og.gain.value = 0.008;
    pan.pan.value = (i / 5) * 2 - 1;
    osc.connect(og); og.connect(pan); pan.connect(tonalGain);
    osc.start();
    tonalOscs.push({ osc: osc, gain: og, pan: pan });
  }

  // ── Spatial: 8 panned tones ────────────────────────────────
  spatialGain = actx.createGain();
  spatialGain.gain.value = L.spatial.vol / 100;
  spatialGain.connect(dryGain);
  spatialGain.connect(convolver);

  for (var i = 0; i < 8; i++) {
    var osc = actx.createOscillator();
    var og  = actx.createGain();
    var pan = actx.createStereoPanner();
    osc.type = 'triangle';
    osc.frequency.value = L.spatial.pit * (0.5 + i * 0.15);
    og.gain.value = 0.004;
    pan.pan.value = (i / 7) * 2 - 1;
    osc.connect(og); og.connect(pan); pan.connect(spatialGain);
    osc.start();
    spatialOscs.push({ osc: osc, gain: og, pan: pan });
  }

  // ── Rhythm: gain node driven by envelope ───────────────────
  rhythmGain = actx.createGain();
  rhythmGain.gain.value = 0;
  rhythmGain.connect(dryGain);
  rhythmGain.connect(convolver);

  var rOsc = actx.createOscillator();
  rOsc.type = 'sine';
  rOsc.frequency.value = 80;
  rOsc.connect(rhythmGain);
  rOsc.start();
  window._rOsc = rOsc;
}

// ── Heartbeat ─────────────────────────────────────────────────
// Two-pulse "lub-dub" at resting BPM, quieter than activation
function triggerHeartbeat(now) {
  if (!actx || activated) return;
  var hbVol = 0.04;

  // Lub
  rhythmGain.gain.cancelScheduledValues(now);
  rhythmGain.gain.setValueAtTime(hbVol, now);
  rhythmGain.gain.exponentialRampToValueAtTime(0.0001, now + 0.06);

  // Dub (slight delay)
  rhythmGain.gain.setValueAtTime(hbVol * 0.65, now + 0.12);
  rhythmGain.gain.exponentialRampToValueAtTime(0.0001, now + 0.20);
}

// ── Update audio from activations ────────────────────────────
function updateAudio(now) {
  if (!actx) return;

  // Mean activation magnitude
  var meanAbs = 0;
  for (var i = 0; i < BUCKETS; i++) meanAbs += Math.abs(acts[i]);
  meanAbs /= BUCKETS;

  // ── Tonal ──────────────────────────────────────────────────
  if (L.tonal.on) {
    tonalGain.gain.setTargetAtTime(L.tonal.vol/100 * (activated ? 1 : 0.15), now, 0.2);
    tonalOscs.forEach(function(o, i) {
      var a   = acts[i % BUCKETS];
      var abs = Math.abs(a);
      var f   = L.tonal.flo + abs * (L.tonal.fhi - L.tonal.flo) * (1 + i*0.2);
      o.osc.frequency.setTargetAtTime(Math.min(f, L.tonal.fhi*1.1), now, 0.15);
      o.osc.detune.setTargetAtTime((i%2===0?1:-1) * L.tonal.det * (1+abs), now, 0.1);
      o.gain.gain.setTargetAtTime(0.006 + abs*0.045, now, 0.15);
    });
  } else {
    tonalGain.gain.setTargetAtTime(0, now, 0.05);
  }

  // ── Spatial ────────────────────────────────────────────────
  if (L.spatial.on) {
    spatialGain.gain.setTargetAtTime(L.spatial.vol/100 * (activated ? 1 : 0.1), now, 0.2);
    spatialOscs.forEach(function(o, i) {
      var bIdx = Math.floor((i / spatialOscs.length) * BUCKETS);
      var a    = acts[bIdx];
      var abs  = Math.abs(a);
      // Pan: activation sign steers left/right
      var basePan = (i / (spatialOscs.length-1)) * 2 - 1;
      var actPan  = basePan + a * (L.spatial.wid/100) * 0.6;
      o.pan.pan.setTargetAtTime(Math.max(-1, Math.min(1, actPan)), now, 0.2);
      o.osc.frequency.setTargetAtTime(L.spatial.pit * (0.5 + i*0.15) * (1 + abs*0.3), now, 0.2);
      o.gain.gain.setTargetAtTime(activated ? 0.005 + abs*0.035 : 0.001, now, 0.2);
    });
  } else {
    spatialGain.gain.setTargetAtTime(0, now, 0.05);
  }

  // ── Rhythm ─────────────────────────────────────────────────
  if (L.rhythm.on && activated) {
    var bpm      = L.rhythm.blo + meanAbs * (L.rhythm.bhi - L.rhythm.blo);
    var interval = 60.0 / Math.max(bpm, 1);
    if (now - lastBeat > interval) {
      lastBeat = now;
      var punchSec = L.rhythm.pun / 1000;
      var vol      = L.rhythm.vol / 100 * meanAbs * 3;
      rhythmGain.gain.cancelScheduledValues(now);
      rhythmGain.gain.setValueAtTime(vol, now);
      rhythmGain.gain.exponentialRampToValueAtTime(0.0001, now + punchSec);
    }
  }

  // ── Reverb driven by entropy ────────────────────────────────
  // (entropy is stored in window.lastEntropy)
  if (wetGain) {
    var ent = window.lastEntropy || 0;
    var rv  = (G.reverb/100) * (0.1 + ent * 0.9) * 0.9;
    wetGain.gain.setTargetAtTime(rv, now, 0.4);
  }
}

// ── Main loop ─────────────────────────────────────────────────
var frameT = 0;
var hbInterval = 0;

function loop() {
  requestAnimationFrame(loop);
  frameT += 0.016;

  // Smooth activations
  for (var i = 0; i < BUCKETS; i++) {
    acts[i] += (actTgt[i] - acts[i]) * 0.07;
  }

  // Decay
  if (activated) {
    decayT += 0.016;
    if (decayT > G.decay * 0.4) {
      for (var i = 0; i < BUCKETS; i++) actTgt[i] *= 0.978;
    }
    if (decayT > G.decay) {
      activated = false; decayT = 0;
      actTgt.fill(0);
      setStatus('idle', null);
    }
  }

  // Heartbeat when idle
  if (!activated && actx) {
    hbInterval += 0.016;
    var hbPeriod = 60 / Math.max(G.hbrate, 1);
    if (hbInterval > hbPeriod) {
      hbInterval = 0;
      triggerHeartbeat(actx.currentTime);
    }
  }

  updateVU();
  if (actx) updateAudio(actx.currentTime);
}
loop();

// ── Status helpers ────────────────────────────────────────────
function setStatus(state, data) {
  var el     = document.getElementById('status-dot');
  var colors = { idle:'#30c070', loading:'#c09030',
                 active:'#e83a5a', settling:'#30c070', error:'#e83a3a' };
  el.style.color  = colors[state] || '#30c070';
  el.textContent  = '\u25cf ' + state.toUpperCase();

  if (data) {
    document.getElementById('info-out').textContent =
      'output \u2192 "' + data.output + '"';
    document.getElementById('info-ent').textContent =
      'H = ' + data.entropy_raw + ' nats  reverb \u2192 ' +
      Math.round(data.entropy_norm * 100) + '%';
  } else if (state === 'idle') {
    document.getElementById('info-out').textContent = '';
    document.getElementById('info-ent').textContent = '';
  }
}

// ── Send prompt ───────────────────────────────────────────────
async function sendPrompt() {
  if (busy) return;
  var prompt = document.getElementById('prompt-input').value.trim();
  if (!prompt) return;

  initAudio();
  busy = true;
  document.getElementById('send-btn').disabled = true;
  setStatus('loading', null);

  try {
    var result = await google.colab.kernel.invokeFunction(
      'ast.sonify', [prompt], {}
    );

    var raw = result.data['text/plain'];
    raw = raw.trim();
    if ((raw.startsWith("'") && raw.endsWith("'")) ||
        (raw.startsWith('"') && raw.endsWith('"'))) {
      raw = raw.slice(1, -1);
    }
    raw = raw.replace(/\\"/g, '"').replace(/\\n/g,'').replace(/\\\\/g,'\\');

    var data = JSON.parse(raw);
    if (data.error) throw new Error(data.error);

    window.lastEntropy = data.entropy_norm || 0;
    for (var i = 0; i < BUCKETS; i++) actTgt[i] = data.activations[i] || 0;
    activated = true; decayT = 0; lastBeat = 0;
    setStatus('active', data);
    setTimeout(function() { if (activated) setStatus('settling', null); }, G.decay * 400);

  } catch(e) {
    setStatus('error', null);
    document.getElementById('info-out').textContent = e.message;
  }

  busy = false;
  document.getElementById('send-btn').disabled = false;
}

function stopAll() {
  actTgt.fill(0); activated = false; decayT = 0;
  setStatus('idle', null);
}

document.getElementById('send-btn').addEventListener('click', sendPrompt);
document.getElementById('stop-btn').addEventListener('click', stopAll);
document.getElementById('prompt-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') sendPrompt();
});
</script>
</body>
</html>
"""

