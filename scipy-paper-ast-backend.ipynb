# ── Imports ──────────────────────────────────────────

import torch
import torch.nn.functional as F
import numpy as np
from transformer_lens import HookedTransformer
from flask import Flask, request, jsonify
from flask_cors import CORS
from pyngrok import ngrok
import threading

device = "cuda" if torch.cuda.is_available() else "cpu"
LAYER  = 8
PORT   = 5000

print(f"Device: {device}")

# ── Load model - tried phi-2 ───────────────────────────────────────

print("Loading gpt-2 large...")
model = HookedTransformer.from_pretrained("gpt2-large", device=device)
model.eval()
print(f"Model loaded — d_model: {model.cfg.d_model}")


# ── CELL 4: Extraction function ──────────────────────────────

hook_name = f"blocks.{LAYER}.hook_resid_pre"

def extract(prompt):
    tokens = model.to_tokens([prompt], prepend_bos=True)

    with torch.no_grad():
        logits = model(tokens)
        probs  = F.softmax(logits[:, -1, :], dim=-1)
        H_raw  = float(-torch.sum(probs * torch.log(probs + 1e-10)).item())
        top_id = int(torch.argmax(logits[:, -1, :], dim=-1).item())

        _, cache = model.run_with_cache(tokens, names_filter=hook_name)
        raw = cache[hook_name][:, -1, :].cpu().float().numpy()[0]  # [768]

    return {
        "output":       model.tokenizer.decode([top_id]).strip(),
        "activations":  raw.tolist(),
        "entropy_raw":  round(H_raw, 3),
        "entropy_norm": round(float(np.clip((H_raw - 3.0) / 5.0, 0.0, 1.0)), 3),
    }


# ── Flask API ────────────────────────────────────────

app = Flask(__name__)
CORS(app)

# ============================================================#
# POST /activate
# It returns raw activations 
# ============================================================


@app.route("/activate", methods=["POST"])
def activate():
    """
    POST /activate
    Body:     { "prompt": "The capital of France is" }

    Response:
    {
      "prompt":       "The capital of France is",
      "output":       "Paris",
      "entropy_raw":  3.821,
      "entropy_norm": 0.164,
      "activations":  [ ...768 floats... ]
    }
    """
    body = request.get_json(force=True)

    if not body or "prompt" not in body:
        return jsonify({"error": "missing field: prompt"}), 400

    result = extract(str(body["prompt"]).strip())
    result["prompt"] = body["prompt"]

    return jsonify(result)

# ============================================================#
# POST /health
# Check if API is fine
# ============================================================

@app.route("/health", methods=["GET"])
def health():
    return jsonify({
        "status":    "ok",
        "model":     "gpt2",
        "layer":     LAYER,
        "act_dims":  model.cfg.d_model,
    })


# ============================================================#
# POST /sequence
# It returns activations at EVERY token position,
# not just the last one.
# The phase portrait needs the full trajectory.
# ============================================================


@app.route("/sequence", methods=["POST"])
def sequence():
    """
    POST /sequence
    Body:  { "prompt": "The capital of France is" }

    Response:
    {
      "prompt":        "The capital of France is",
      "n_tokens":      7,
      "tokens":        ["The", " capital", " of", " France", " is"],
      "entropy_raw":   3.821,
      "entropy_norm":  0.164,
      "output":        "Paris",
      "activations":   [
          [...1024 floats...],   <- token 0 (BOS)
          [...1024 floats...],   <- token 1
          ...                    <- one row per token
      ]
    }

    Shape of activations: [n_tokens, d_model]
    """
    body = request.get_json(force=True)

    if not body or "prompt" not in body:
        return jsonify({"error": "missing field: prompt"}), 400

    prompt = str(body["prompt"]).strip()
    tokens = model.to_tokens([prompt], prepend_bos=True)   # [1, n_tokens]

    with torch.no_grad():
        # Output + entropy (from last token logits)
        logits = model(tokens)
        probs  = F.softmax(logits[:, -1, :], dim=-1)
        H_raw  = float(-torch.sum(probs * torch.log(probs + 1e-10)).item())
        top_id = int(torch.argmax(logits[:, -1, :], dim=-1).item())

        # All-token activations
        _, cache = model.run_with_cache(tokens, names_filter=hook_name)
        acts = cache[hook_name][0]   # [n_tokens, d_model]

    # Decode token strings for labelling in the portrait
    token_ids  = tokens[0].tolist()
    token_strs = [model.tokenizer.decode([t]) for t in token_ids]

    return jsonify({
        "prompt":       prompt,
        "n_tokens":     len(token_ids),
        "tokens":       token_strs,
        "output":       model.tokenizer.decode([top_id]).strip(),
        "entropy_raw":  round(H_raw, 3),
        "entropy_norm": round(float(np.clip((H_raw - 3.0) / 5.0, 0.0, 1.0)), 3),
        "activations":  acts.cpu().float().numpy().tolist(),
    })

# ── Start server + ngrok ─────────────────────────────

NGROK_TOKEN = ""   # ← paste token from dashboard.ngrok.com

ngrok.set_auth_token(NGROK_TOKEN)
ngrok.kill()

tunnel     = ngrok.connect(PORT)
public_url = tunnel.public_url

print("=" * 56)
print(f"Public URL : {public_url}")
print(f"Endpoint   : {public_url}/activate")
print(f"Endpoint   : {public_url}/sequence")
print(f"Health     : {public_url}/health")
print("=" * 56)
print()
print("Example curl:")
print(f'  curl -X POST {public_url}/activate \\')
print(f'       -H "Content-Type: application/json" \\')
print(f'       -d \'{{"prompt": "The capital of France is"}}\'')

thread = threading.Thread(
    target=lambda: app.run(port=PORT, use_reloader=False)
)
thread.daemon = True
thread.start()
